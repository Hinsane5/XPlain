<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- XPlain is not sandboxed (Developer ID distribution, not the App Store).
	     Screen Recording needs no entitlement — it's gated by TCC at runtime.
	     The microphone (M5.7b), under the hardened runtime, needs this one. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
